# Derm Foundation Vertex AI Configuration
# Copy this file to .env and fill in your actual values

# GCP Project ID
DERM_VERTEX_PROJECT=your-project-id

# Vertex AI Endpoint ID (numeric)
DERM_VERTEX_ENDPOINT=your-endpoint-id

# Vertex AI Region
DERM_VERTEX_REGION=us-central1

# Private Service Connect (PSC) Internal IP
DERM_VERTEX_PSC_IP=10.x.x.x

